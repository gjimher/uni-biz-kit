#!/usr/bin/env python3

"""
UniBizKit CLI Entry Point

This script provides the main entry point for the UniBizKit command line interface.
"""

import sys
import os

# Add the src directory to the Python path
sys.path.insert(0, os.path.join(os.path.dirname(__file__), '..', 'src'))

from unibizkit.main import main

if __name__ == '__main__':
    main()