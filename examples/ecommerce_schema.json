{
  "version": "1.0.0",
  "name": "ECommerce Platform",
  "description": "A complete e-commerce business application with products, customers, orders, and categories",
  "concepts": [
    {
      "name": "product",
      "pluralName": "products",
      "description": "A product available for sale in the e-commerce platform",
      "fields": [
        {
          "name": "name",
          "type": "string",
          "required": true,
          "unique": false,
          "minLength": 2,
          "maxLength": 100,
          "description": "The name of the product"
        },
        {
          "name": "description",
          "type": "string",
          "required": false,
          "maxLength": 1000,
          "description": "Detailed description of the product"
        },
        {
          "name": "price",
          "type": "decimal",
          "required": true,
          "precision": 10,
          "scale": 2,
          "min": 0.01,
          "description": "Price of the product"
        },
        {
          "name": "stock_quantity",
          "type": "integer",
          "required": true,
          "min": 0,
          "default": 0,
          "description": "Available stock quantity"
        },
        {
          "name": "sku",
          "type": "string",
          "required": true,
          "unique": true,
          "minLength": 3,
          "maxLength": 50,
          "description": "Stock Keeping Unit - unique identifier"
        },
        {
          "name": "status",
          "type": "enum",
          "required": true,
          "enumValues": ["draft", "published", "archived"],
          "default": "draft",
          "description": "Current status of the product"
        },
        {
          "name": "is_featured",
          "type": "boolean",
          "required": false,
          "default": false,
          "description": "Whether the product is featured"
        }
      ]
    },
    {
      "name": "category",
      "pluralName": "categories",
      "description": "Product categories for organizing the catalog",
      "fields": [
        {
          "name": "name",
          "type": "string",
          "required": true,
          "unique": true,
          "minLength": 2,
          "maxLength": 50,
          "description": "Name of the category"
        },
        {
          "name": "description",
          "type": "string",
          "required": false,
          "maxLength": 500,
          "description": "Description of the category"
        },
        {
          "name": "slug",
          "type": "string",
          "required": true,
          "unique": true,
          "minLength": 2,
          "maxLength": 50,
          "description": "URL-friendly slug for the category"
        },
        {
          "name": "parent_id",
          "type": "integer",
          "required": false,
          "description": "Parent category ID for hierarchical categories"
        }
      ],
      "relationships": [
        {
          "type": "many-to-many",
          "target": "product",
          "fieldName": "products",
          "targetFieldName": "categories",
          "ownership": false,
          "required": false
        }
      ]
    },
    {
      "name": "customer",
      "pluralName": "customers",
      "description": "Customers who purchase products",
      "fields": [
        {
          "name": "first_name",
          "type": "string",
          "required": true,
          "minLength": 1,
          "maxLength": 50,
          "description": "Customer's first name"
        },
        {
          "name": "last_name",
          "type": "string",
          "required": true,
          "minLength": 1,
          "maxLength": 50,
          "description": "Customer's last name"
        },
        {
          "name": "email",
          "type": "string",
          "required": true,
          "unique": true,
          "minLength": 5,
          "maxLength": 100,
          "description": "Customer's email address"
        },
        {
          "name": "phone",
          "type": "string",
          "required": false,
          "minLength": 10,
          "maxLength": 20,
          "description": "Customer's phone number"
        },
        {
          "name": "address",
          "type": "string",
          "required": false,
          "maxLength": 200,
          "description": "Customer's shipping address"
        }
      ]
    },
    {
      "name": "order",
      "pluralName": "orders",
      "description": "Customer orders containing products",
      "fields": [
        {
          "name": "order_number",
          "type": "string",
          "required": true,
          "unique": true,
          "minLength": 5,
          "maxLength": 20,
          "description": "Unique order number"
        },
        {
          "name": "order_date",
          "type": "datetime",
          "required": true,
          "description": "When the order was placed"
        },
        {
          "name": "total_amount",
          "type": "decimal",
          "required": true,
          "precision": 10,
          "scale": 2,
          "min": 0,
          "description": "Total order amount"
        },
        {
          "name": "status",
          "type": "enum",
          "required": true,
          "enumValues": ["pending", "processing", "shipped", "delivered", "cancelled"],
          "default": "pending",
          "description": "Current order status"
        },
        {
          "name": "shipping_address",
          "type": "string",
          "required": true,
          "maxLength": 200,
          "description": "Shipping address for the order"
        },
        {
          "name": "billing_address",
          "type": "string",
          "required": false,
          "maxLength": 200,
          "description": "Billing address for the order"
        }
      ],
      "relationships": [
        {
          "type": "belongs-to",
          "target": "customer",
          "fieldName": "customer",
          "targetFieldName": "orders",
          "ownership": false,
          "required": true
        }
      ]
    },
    {
      "name": "order_item",
      "pluralName": "order_items",
      "description": "Individual items within an order",
      "fields": [
        {
          "name": "quantity",
          "type": "integer",
          "required": true,
          "min": 1,
          "description": "Quantity of the product"
        },
        {
          "name": "unit_price",
          "type": "decimal",
          "required": true,
          "precision": 10,
          "scale": 2,
          "min": 0,
          "description": "Price per unit at time of purchase"
        },
        {
          "name": "total_price",
          "type": "decimal",
          "required": true,
          "precision": 10,
          "scale": 2,
          "min": 0,
          "description": "Total price for this order item"
        }
      ],
      "relationships": [
        {
          "type": "belongs-to",
          "target": "order",
          "fieldName": "order",
          "targetFieldName": "items",
          "ownership": true,
          "required": true
        },
        {
          "type": "belongs-to",
          "target": "product",
          "fieldName": "product",
          "targetFieldName": "order_items",
          "ownership": false,
          "required": true
        }
      ]
    }
  ]
}
