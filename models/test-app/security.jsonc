{
  "$schema": "../../schemas/security_schema.json",
  "authentication_required": true,
  "registration": {
    "allow": true,
    "role": "user"
  },
  "sso": {
    "enabled": true,
    "domain": "dev.local",
    "role_claim": "roles",
    "default_role": "user"
  },
  "roles": [
    {
      "name": "admin",
      "description": "System Administrator"
    },
    {
      "name": "user",
      "description": "Standard User",
      "profile_concept": "customer"
    }
  ],
  "users": [
    {
      "email": "admin@test.com",
      "password": "adminadmin",
      "roles": ["admin"]
    },
    {
      "email": "user1@test.com",
      "password": "useruser",
      "roles": ["user"]
    },
    {
      "email": "user2@test.com",
      "password": "useruser",
      "roles": ["user"]
    }
  ],
  "rules_level_2": [
    {
      "role": "_anon",
      "concept": "product",
      "field": "*",
      "access": "read"
    },
    {
      "role": "_anon",
      "concept": "category",
      "field": "*",
      "access": "read"
    },
    {
      "role": "user",
      "concept": "customer",
      "field": "*",
      "access": "owner_write"
    },
    {
      "role": "user",
      "concept": "order",
      "field": "*",
      "access": "owner_write"
    }
  ],
  "rules_level_3": [
    {
      "role": "user",
      "concept": "*",
      "field": "admin_*",
      "access": "read"
    }
  ]
}
