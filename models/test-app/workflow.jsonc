{
  "$schema": "../../schemas/workflow_schema.json",
  "workflow_rules": [
    {
      "name": "order_workflow",
      "description": "Tracks the lifecycle of a customer order from creation to delivery.",
      "concepts": "order",
      // States define the valid lifecycle steps. Transitions are always sequential
      // (each state can only move to the next one in the list).
      "states": [
        // owners: roles that may act on records in this state; both user and admin can submit initial → ordered
        { "name": "initial", "description": "Order just created, pending confirmation by the customer.", "owners": ["user", "admin"] },
        // Only admins can advance the order once the customer has submitted it
        { "name": "ordered", "owners": ["admin"] },
        { "name": "accepted", "owners": ["admin"] },
        { "name": "sent", "owners": ["admin"] },
        { "name": "delivered", "owners": ["admin"] }
      ]
    }
  ]
}
