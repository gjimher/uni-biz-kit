{
  "$schema": "../../schemas/system_schema.json",
  // smtp: outgoing mail configuration used by Supabase Auth for verification emails,
  // password resets, and magic links. Points to a local dev mail catcher by default.
  "smtp": {
    "host": "127.0.0.1",
    "port": 3010,
    "from_email": "noreply@localhost"
  },
  // payments: generates the 'payment' edge function (provider proxy).
  // dev_mode uses the built-in simulator, so no Stripe credentials are needed.
  "payments": {
    "dev_mode": true,
    "concept": "order",
    "amount_field": "total_amount"
  }
}
