{
  "$schema": "../../schemas/deployment_schema.json",
  // base_uri: URL prefix under which the app is served.
  // Use "/" for a root deployment. Using a sub-path (e.g. "/test") allows hosting
  // multiple apps on the same domain. All asset and API paths are resolved relative to this.
  "base_uri": "/test",
  // "dev" deploys recreate database and storage from the generated schema and seeds.
  "prod_versioning": "dev"
}
