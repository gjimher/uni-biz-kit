{
  "$schema": "../../schemas/presentation_schema.json",
  "menu": [
    {
      "label": "Catalog",
      "children": [
        { "label": "Products", "concept": "product" },
        { "label": "Categories", "concept": "category" }
      ]
    },
    {
      "label": "Sales",
      "children": [
        { "label": "Orders", "concept": "order" },
        { "label": "Customers", "concept": "customer" }
      ]
    },
    {
      "label": "Test",
      "children": [
        { "label": "Field checkers", "concept": "field_checker" }
      ]
    }
  ],
  "list_field_rules_level_2": {
    // product: remove fields after price, add sku to the end and remove details field
    //  same as: "!*,name,description,details,price,sku"
    "product": "!>price, sku, !details",
    // category: hide slug (URL-only field, not useful in admin lists)
    "category": "!slug",
    // order: show id as first column and remove fields after total_amount
    "order": "id_presentation[0], !>total_amount",
    // customer: remove fields after email
    "customer": "!>email"
  },
  "list_sort": {
    // Newest orders first
    "order": "order_date DESC"
  }
}
