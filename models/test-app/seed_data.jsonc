{
  "$schema": "../../schemas/seed_data_schema.json",
  // include_test_data: when true, the generator also creates synthetic faker-based test records
  // in addition to the explicit records defined below.
  // Set to false in production models to load only the mandatory seed records.
  "include_test_data": true,
  "records": {
    "category": [
      { "id": "accessories", "parent": null, "name": "Seeded Accessories", "description": "Category loaded from seed_data.json", "slug": "seeded-accessories" }
    ],
    "product": [
      {
        "id": "keyboard",
        "name": "Seeded Keyboard",
        "description": "Product loaded from seed_data.json",
        "price": 49.99,
        "stock_quantity": 25,
        "sku": "SEED-KBD-001",
        "status": "published",
        "is_featured": true,
        // Reference a seeded category by its string id
        "categories": ["accessories"],
        // documents: seed files attached to this record at deploy time; content_base64 is the Base64 file content
        "documents": [
          // Decoded: "Initial product datasheet\n"
          { "tag": "datasheet", "name": "seeded-keyboard.txt", "content_type": "text/plain", "content_base64": "SW5pdGlhbCBwcm9kdWN0IGRhdGFzaGVldAo=" }
        ]
      }
    ]
  }
}
