{
  "$schema": "../../schemas/system_schema.json",
  "smtp": {
    "host": "127.0.0.1",
    "port": 3010,
    "from_email": "noreply@b2c.local"
  },
  // payments: generates the 'payment' edge function (Stripe proxy).
  // dev_mode uses the built-in simulator — no Stripe credentials needed;
  // the storefront checkout charges grand_total before confirming the order.
  "payments": {
    "dev_mode": true,
    "concept": "order",
    "amount_field": "grand_total"
  }
}
