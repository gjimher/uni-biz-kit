{
  "version": "1.0.0",
  "name": "ECommerce Platform",
  "description": "A complete e-commerce business application with products, customers, orders, and categories",
  "concepts": [
    {
      "name": "product",
      "plural_name": "products",
      "description": "A product available for sale in the e-commerce platform",
      "id_presentation": {
        "fields": ["name"]
      },
      "fields": [
        {
          "name": "name",
          "type": "string",
          "required": true,
          "unique": false,
          "min_length": 2,
          "max_length": 100,
          "size": "s",
          "description": "The name of the product"
        },
        {
          "name": "description",
          "type": "string",
          "required": false,
          "max_length": 1000,
          "size": "l",
          "description": "Detailed description of the product"
        },
        {
          "name": "price",
          "type": "decimal",
          "required": true,
          "precision": 10,
          "scale": 2,
          "min": 0.01,
          "description": "Price of the product"
        },
        {
          "name": "stock_quantity",
          "type": "integer",
          "required": true,
          "min": 0,
          "default": 0,
          "description": "Available stock quantity"
        },
        {
          "name": "sku",
          "type": "string",
          "required": true,
          "unique": true,
          "min_length": 3,
          "max_length": 50,
          "description": "Stock Keeping Unit - unique identifier"
        },
        {
          "name": "status",
          "type": "enum",
          "required": true,
          "enum_values": ["draft", "published", "archived"],
          "default": "draft",
          "description": "Current status of the product"
        },
        {
          "name": "is_featured",
          "type": "boolean",
          "required": false,
          "default": false,
          "description": "Whether the product is featured"
        }
      ]
    },
    {
      "name": "category",
      "plural_name": "categories",
      "id_presentation": {
        "fields": ["parent.id_presentation", "name"],
        "separator": "/",
        "show": true
      },
      "fields": [
        {
          "name": "name",
          "type": "string",
          "required": true,
          "unique": true,
          "min_length": 2,
          "max_length": 50,
          "description": "Name of the category"
        },
        {
          "name": "description",
          "type": "string",
          "required": false,
          "max_length": 500,
          "description": "Description of the category"
        },
        {
          "name": "slug",
          "type": "string",
          "required": true,
          "unique": true,
          "min_length": 2,
          "max_length": 50,
          "description": "URL-friendly slug for the category"
        },
        {
          "name": "parent",
          "type": "relation_to_one",
          "subtype": "part_of",
          "target": "category",

          "description": "Parent category"
        }
      ]
    },
    {
      "name": "customer",
      "plural_name": "customers",
      "description": "Customers who purchase products",
      "data_size": "m",
      "id_presentation": {
        "fields": ["first_name", "last_name"],
        "separator": ", "
      },
      "fields": [
        {
          "name": "first_name",
          "type": "string",
          "required": true,
          "min_length": 1,
          "max_length": 50,
          "description": "Customer's first name"
        },
        {
          "name": "last_name",
          "type": "string",
          "required": true,
          "min_length": 1,
          "max_length": 50,
          "description": "Customer's last name"
        },
        {
          "name": "email",
          "type": "string",
          "required": true,
          "unique": true,
          "min_length": 5,
          "max_length": 100,
          "description": "Customer's email address"
        },
        {
          "name": "phone",
          "type": "string",
          "required": false,
          "min_length": 10,
          "max_length": 20,
          "description": "Customer's phone number"
        },
        {
          "name": "address",
          "type": "string",
          "required": false,
          "max_length": 200,
          "size": "m",
          "description": "Customer's shipping address"
        }
      ]
    },
    {
      "name": "order",
      "plural_name": "orders",
      "description": "Customer orders containing products",
      "id_presentation": {
        "fields": ["id"]
      },
      "fields": [
        {
          "name": "customer",
          "type": "relation_to_one",
          "subtype": "related_to",
          "target": "customer",

          "required": true,
          "description": "Customer who placed the order"
        },
        {
          "name": "order_date",
          "type": "datetime",
          "required": true,
          "description": "When the order was placed"
        },
        {
          "name": "total_amount",
          "type": "decimal",
          "required": true,
          "precision": 10,
          "scale": 2,
          "min": 0,
          "description": "Total order amount"
        },
        {
          "name": "status",
          "type": "enum",
          "required": true,
          "enum_values": ["pending", "processing", "shipped", "delivered", "cancelled"],
          "default": "pending",
          "description": "Current order status"
        },
        {
          "name": "shipping_address",
          "type": "string",
          "required": true,
          "max_length": 200,
          "size": "m",
          "description": "Shipping address for the order"
        },
        {
          "name": "billing_address",
          "type": "string",
          "required": false,
          "max_length": 200,
          "size": "m",
          "description": "Billing address for the order"
        }
      ]
    },
    {
      "name": "order_item",
      "plural_name": "order_items",
      "description": "Individual items within an order",
      "id_presentation": {
        "fields": ["id"]
      },
      "fields": [
        {
          "name": "product",
          "type": "relation_to_one",
          "subtype": "related_to",
          "target": "product",

          "required": false,
          "description": "Product ordered"
        },
        {
          "name": "quantity",
          "type": "integer",
          "required": true,
          "min": 1,
          "description": "Quantity of the product"
        },
        {
          "name": "unit_price",
          "type": "decimal",
          "required": true,
          "precision": 10,
          "scale": 2,
          "min": 0,
          "description": "Price per unit at time of purchase"
        },
        {
          "name": "total_price",
          "type": "decimal",
          "required": true,
          "precision": 10,
          "scale": 2,
          "min": 0,
          "calculated": "quantity*unit_price",
          "description": "Total price for this order item"
        },
        {
          "name": "order",
          "type": "relation_to_one",
          "subtype": "part_of",
          "target": "order"

        }
      ]
    }
  ]
}
