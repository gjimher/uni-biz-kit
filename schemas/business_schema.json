{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Business Application Schema",
  "description": "Schema for defining business concepts and their relationships",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "name": {
      "type": "string",
      "description": "Name of the business application"
    },
    "description": {
      "type": "string",
      "description": "Description of the business application"
    },
    "concepts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the concept (singular, snake_case recommended)"
          },
          "plural_name": {
            "type": "string",
            "description": "Plural name of the concept (snake_case recommended)"
          },
          "description": {
            "type": "string",
            "description": "Description of the concept"
          },
    "presentation_id": {
      "type": "object",
      "properties": {
        "fields": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Fields to be used for the generated presentation string (e.g. ['first_name', 'last_name'] for 'John Doe')"
        },
        "separator": {
          "type": "string",
          "description": "Separator to use between fields in id_presentation",
          "default": " "
        },
        "show": {
          "type": "boolean",
          "description": "Whether to show the id_presentation field in list and edit views",
          "default": false
        }
      },
      "required": ["fields"],
      "additionalProperties": false,
      "description": "Configuration for the presentation ID (id_presentation) of the concept"
    },
          "fields": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Field name (snake_case recommended)"
                },
                "type": {
                  "type": "string",
                  "description": "Field type",
                  "enum": ["string", "integer", "decimal", "enum", "boolean", "date", "datetime"]
                },
                "required": {
                  "type": "boolean",
                  "description": "Whether the field is required",
                  "default": false
                },
                "unique": {
                  "type": "boolean",
                  "description": "Whether the field must be unique",
                  "default": false
                },
                "default": {
                  "type": ["string", "number", "boolean", "null"],
                  "description": "Default value for the field"
                },
                "min_length": {
                  "type": "integer",
                  "description": "Minimum length for string fields",
                  "minimum": 0
                },
                "max_length": {
                  "type": "integer",
                  "description": "Maximum length for string fields",
                  "minimum": 1
                },
                "size": {
                  "type": "string",
                  "description": "Size of text field (s, m, l) - only applicable to string fields",
                  "enum": ["s", "m", "l"]
                },
                "min": {
                  "type": "number",
                  "description": "Minimum value for numeric fields"
                },
                "max": {
                  "type": "number",
                  "description": "Maximum value for numeric fields"
                },
                "precision": {
                  "type": "integer",
                  "description": "Precision for decimal fields",
                  "minimum": 1,
                  "maximum": 10
                },
                "scale": {
                  "type": "integer",
                  "description": "Scale for decimal fields",
                  "minimum": 0,
                  "maximum": 10
                },
                "enum_values": {
                  "type": "array",
                  "description": "Allowed values for enum fields",
                  "minItems": 1,
                  "items": {
                    "type": "string"
                  }
                },
                "description": {
                  "type": "string",
                  "description": "Description of the field"
                }
              },
              "required": ["name", "type"],
              "additionalProperties": false
            }
          },
          "relationships": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "description": "Relationship type",
                  "enum": ["one-to-many", "many-to-many", "belongs-to"]
                },
                "target": {
                  "type": "string",
                  "description": "Target concept name"
                },
                "field_name": {
                  "type": "string",
                  "description": "Field name for the relationship (snake_case recommended)"
                },
                "target_field_name": {
                  "type": "string",
                  "description": "Field name on the target concept (snake_case recommended)"
                },
                "ownership": {
                  "type": "boolean",
                  "description": "Whether this is an ownership relationship",
                  "default": false
                },
                "required": {
                  "type": "boolean",
                  "description": "Whether the relationship is required",
                  "default": false
                }
              },
              "required": ["type", "target"],
              "additionalProperties": false
            }
          }
        },
        "required": ["name", "fields"],
        "additionalProperties": false
      }
    }
  },
  "required": ["version", "name", "concepts"],
  "additionalProperties": false
}
