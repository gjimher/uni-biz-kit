{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Workflow Schema",
  "description": "Schema for defining business workflows",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "workflow_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string",
            "default": ""
          },
          "concepts": {
            "type": "string",
            "description": "Comma-separated list of concepts or '*' for all"
          },
          "states": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "description": { "type": "string", "default": "" },
                "owners": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "assigners": {
                  "type": "array",
                  "description": "Roles that can change the task owner (state_task_owner) while the record is in this state",
                  "items": { "type": "string" }
                },
                "retain_task_owner": {
                  "type": "boolean",
                  "description": "When entering this state, keep the previous task owner instead of clearing it back to the assignable pool",
                  "default": false
                }
              },
              "required": ["name", "owners", "assigners"],
              "additionalProperties": false
            }
          }
        },
        "required": ["name", "concepts", "states"],
        "additionalProperties": false
      }
    }
  },
  "required": ["workflow_rules"],
  "additionalProperties": false
}
