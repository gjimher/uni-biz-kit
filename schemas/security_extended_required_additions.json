{
  "properties": {
    "_acl": {
      "type": "object",
      "description": "Calculated security rules organized for easy lookup",
      "additionalProperties": {
        "type": "object",
        "description": "Concept level security rules",
        "properties": {
          "_main": {
            "type": "object",
            "description": "Concept-level access per role. Values: 'read' = SELECT only; 'write' = full INSERT/UPDATE/DELETE for all rows; 'owner_write' = INSERT/UPDATE/DELETE only on rows owned by the authenticated user.",
            "additionalProperties": {
              "type": "string",
              "enum": ["read", "write", "owner_write"]
            }
          },
          "_fields": {
            "type": "object",
            "description": "Field-level access overrides per role. Same access level values as _main. A field entry overrides the concept-level rule for that specific field.",
            "additionalProperties": {
              "type": "object",
              "additionalProperties": {
                "type": "string",
                "enum": ["read", "write", "owner_write"]
              }
            }
          }
        },
        "required": ["_main", "_fields"]
      }
    },
    "_profile_concepts": {
      "type": "array",
      "description": "Resolved role-to-profile concept mappings",
      "items": {
        "type": "object",
        "properties": {
          "role": { "type": "string" },
          "concept": { "type": "string" }
        },
        "required": ["role", "concept"],
        "additionalProperties": false
      }
    }
  },
  "required": ["_acl", "_profile_concepts", "roles", "users"]
}
