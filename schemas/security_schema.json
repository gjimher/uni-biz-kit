{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Security Schema",
  "description": "Schema for defining application security settings",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Path to the JSON schema"
    },
    "authentication_required": {
      "type": "boolean",
      "description": "Whether authentication is required to access the application",
      "default": true
    },
    "roles": {
      "type": "array",
      "description": "Initial roles to seed. If not provided and authentication is required, 'admin' and 'user' roles are created by default.",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" }
        },
        "required": ["name"]
      }
    },
    "users": {
      "type": "array",
      "description": "Initial users to seed. If not provided and authentication is required, default users 'admin@test.com' and 'user@test.com' are created.",
      "items": {
        "type": "object",
        "properties": {
          "email": { "type": "string" },
          "password": { "type": "string" },
          "roles": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["email", "password", "roles"]
      }
    },
    "rules_level_1": {
      "type": "array",
      "description": "General security rules for role-based access control. Lower priority.",
      "items": { "$ref": "#/$defs/rule" },
      "default": [
        {"concept": "*", "role": "admin", "access": "write", "field": "*"},
        {"concept": "*", "role": "user", "access": "read", "field": "*"}
      ]
    },
    "rules_level_2": {
      "type": "array",
      "description": "Specific security rules for role-based access control. Medium priority.",
      "items": { "$ref": "#/$defs/rule" },
      "default": []
    },
    "rules_level_3": {
      "type": "array",
      "description": "Exception security rules for role-based access control. High priority.",
      "items": { "$ref": "#/$defs/rule" },
      "default": []
    }
  },
  "$defs": {
    "rule": {
      "type": "object",
      "properties": {
        "concept": { "type": "string", "description": "Concept name or '*' for all" },
        "role": { "type": "string", "description": "Role name (e.g., 'admin', 'user')" },
        "access": { "enum": ["read", "write", "owner_write"], "description": "Access level" },
        "field": { "type": "string", "description": "Field name or '*' for all fields", "default": "*" }
      },
      "required": ["concept", "role", "access"]
    }
  },
  "required": ["authentication_required"],
  "additionalProperties": false
}
