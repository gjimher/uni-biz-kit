{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Business Application Schema",
  "description": "Schema for defining business concepts and their relationships",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Path to the JSON schema"
    },
    "version": {
      "type": "string",
      "description": "Schema version",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "name": {
      "type": "string",
      "description": "Application name"
    },
    "description": {
      "type": "string",
      "description": "Application description"
    },
    "concepts": {
      "type": "array",
      "description": "List of business concepts",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Concept name (snake_case recommended)"
          },
          "plural_name": {
            "type": "string",
            "description": "Plural name of the concept"
          },
          "description": {
            "type": "string",
            "description": "Description of the concept"
          },
          "checks": {
            "type": "array",
            "description": "List of SQL check constraints",
            "items": { "type": "string" },
            "default": []
          },
          "data_size": {
            "type": "string",
            "description": "Expected data volume (s: <100, m: <10000, l: >10000)",
            "enum": ["s", "m", "l"],
            "default": "s"
          },
          "id_presentation": {
            "type": "object",
            "properties": {
              "fields": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Fields used to generate the presentation ID",
                "minItems": 1
              },
              "separator": {
                "type": "string",
                "description": "Separator used between fields in presentation ID",
                "default": " "
              },
              "show": {
                "type": "boolean",
                "description": "Whether to show the presentation ID in the UI",
                "default": false
              }
            },
            "required": ["fields"]
          },
          "documents": {
            "type": "object",
            "description": "Document management configuration for this concept",
            "properties": {
              "enabled": {
                "type": "boolean",
                "description": "Whether document management is active for this concept",
                "default": false
              },
              "versioned": {
                "type": "boolean",
                "description": "Whether documents support versioning",
                "default": false
              },
              "tags": {
                "type": "array",
                "description": "Allowed document tag values (enum)",
                "items": { "type": "string" },
                "minItems": 1
              }
            },
            "required": ["tags"],
            "additionalProperties": false
          },
          "fields": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Field name (snake_case recommended)"
                },
                "type": {
                  "type": "string",
                  "description": "Field type",
                  "enum": [
                    "string",
                    "integer",
                    "decimal",
                    "enum",
                    "boolean",
                    "date",
                    "datetime",
                    "relation_to_one",
                    "relation_to_many"
                  ]
                },
                "subtype": {
                  "type": "string",
                  "description": "Subtype for fields. 'part_of'/'related_to' for relations, 'money' for decimal.",
                  "enum": ["part_of", "related_to", "money"]
                },
                "target": {
                  "type": "string",
                  "description": "Target concept name for relations"
                },
                "required": {
                  "type": "boolean",
                  "description": "Whether the field is required. Defaults to false, except for relation_to_one with subtype 'part_of' where it defaults to true.",
                  "default": false
                },
                "unique": {
                  "type": "boolean",
                  "description": "Whether the field must be unique",
                  "default": false
                },
                "default": {
                  "type": ["string", "number", "boolean", "null"],
                  "description": "Default value for the field"
                },
                "min_length": {
                  "type": "integer",
                  "description": "Minimum length for string fields",
                  "minimum": 0
                },
                "max_length": {
                  "type": "integer",
                  "description": "Maximum length for string fields",
                  "minimum": 1
                },
                "size": {
                  "type": "string",
                  "description": "Size of text field (s, m, l) - only applicable to string fields",
                  "enum": ["s", "m", "l"],
                  "default": "s"
                },
                "min": {
                  "type": "number",
                  "description": "Minimum value for numeric fields"
                },
                "max": {
                  "type": "number",
                  "description": "Maximum value for numeric fields"
                },
                "precision": {
                  "type": "integer",
                  "description": "Precision for decimal fields",
                  "minimum": 1,
                  "maximum": 10
                },
                "scale": {
                  "type": "integer",
                  "description": "Scale for decimal fields",
                  "minimum": 0,
                  "maximum": 10
                },
                "enum_values": {
                  "type": "array",
                  "description": "Allowed values for enum fields",
                  "items": { "type": "string" },
                  "default": []
                },
                "calculated": {
                  "type": "string",
                  "description": "SQL expression for a generated/calculated field"
                },
                "description": {
                  "type": "string",
                  "description": "Description of the field"
                }
              },
              "required": ["name", "type"],
              "additionalProperties": false
            }
          }
        },
        "required": ["name", "fields", "id_presentation"],
        "additionalProperties": false
      }
    }
  },
  "required": ["version", "name", "concepts"],
  "additionalProperties": false
}